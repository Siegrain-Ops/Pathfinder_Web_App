# ── Local development (SQLite) ───────────────────────────────────────────────
# DATABASE_URL="file:./prisma/dev.db"

# ── Docker / MySQL ───────────────────────────────────────────────────────────
# DATABASE_URL="mysql://pathfinder:pathfinder@localhost:3306/pathfinder"

DATABASE_URL="file:./prisma/dev.db"
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Set to "true" in production to enforce Secure cookies
COOKIE_SECURE=false
