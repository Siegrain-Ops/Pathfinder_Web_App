# ── Local development (SQLite) ───────────────────────────────────────────────
# DATABASE_URL="file:./prisma/dev.db"

# ── Docker / MySQL ───────────────────────────────────────────────────────────
# DATABASE_URL="mysql://pathfinder:pathfinder@localhost:3306/pathfinder"

DATABASE_URL="file:./prisma/dev.db"
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Set to "true" in production to enforce Secure cookies
COOKIE_SECURE=false

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# "From" address — must be from a verified domain in your Resend account
MAIL_FROM=Pathfinder App <noreply@yourdomain.com>
# Base URL of the frontend (used to build links in emails)
APP_BASE_URL=http://localhost:5173
