# ── Docker Compose environment variables ────────────────────────────────────
# Copy this file to .env and adjust values before running docker compose.
# These variables are consumed by docker-compose.yml only.
# The backend application reads its own backend/.env (or the Docker env section).

# MySQL credentials (used by the `db` service and injected into `backend`)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=pathfinder
MYSQL_USER=pathfinder
MYSQL_PASSWORD=pathfinder
