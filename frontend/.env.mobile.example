# ── Mobile build environment (Capacitor / Android) ───────────────────────────
#
# Copy to .env.mobile and fill in your values, then run:
#   npm run build:mobile
#
# The Capacitor Android WebView loads the bundled dist/ assets and makes
# HTTP requests to VITE_API_BASE_URL directly — no proxy involved.

# Full URL of your production backend (required for mobile builds)
VITE_API_BASE_URL=https://your-backend.up.railway.app
